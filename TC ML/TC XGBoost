    secondary_local_paths.append(local_path)

#Paths and parameters
primary_data_path = primary_local_path
output_dir = '/content/results/'
drive_output_dir = '/content/drive/My Drive/FinalTCRuns/'
test_size = 0.25
val_size = 0.333
random_state = 321

#Features
feature_cols = [
    'Mean Control', 'Mean Test', 'Std Control', 'Std Test',
    'Intercept Control', 'Slope Control', 'Intercept Test', 'Slope Test',
    'IQR Control', 'IQR Test', 'Stability Control', 'Stability Test',
    'PND Control-Test', 'Highest Response Condition', 'Cluster Similarity Test'
]

#Search parameters
phase1_trials = 15
phase2_trials = 15
threshold_range = np.arange(0.01, 1.0, 0.01)

#Load and preprocess data
def load_and_preprocess_data(file_path, feature_cols, remove_nans=True):
    if not os.path.exists(file_path):
        print(f"File not found: {file_path}")
        return None, None

    data = pd.read_csv(file_path)
    print(f"Loaded: {file_path}, shape: {data.shape}")

    if data['Differentiation Type'].dtype == object:
        data['Differentiation Type'] = data['Differentiation Type'].map({
            'differentiated': 1, 'undifferentiated': 0
        })

    X = data[feature_cols].values
    y = data['Differentiation Type'].values

    if remove_nans: #problem-solved
        nan_mask = ~(np.isnan(X).any(axis=1) | np.isnan(y))
        removed = (~nan_mask).sum()
        X = X[nan_mask]
        y = y[nan_mask]
        if removed > 0:
            print(f"Removed {removed} rows with NaN values")

    print(f"Final shape: X={X.shape}, y={y.shape}")
    print(f"Class distribution: {dict(zip(*np.unique(y, return_counts=True)))}")
    return X, y

#Optimize threshold
def optimize_threshold(y_true, y_proba):
    best_threshold = 0.5
    best_score = -1
    for t in threshold_range:
        y_pred = (y_proba >= t).astype(int)
        if len(np.unique(y_pred)) < 2:
            continue
        score = cohen_kappa_score(y_true, y_pred)
        if score > best_score:
            best_score = score
            best_threshold = t
    return best_threshold, best_score

#Get neighboring values for grid search
def get_neighbors(value, options):
    if value in options:
        idx = options.index(value)
    else:
        idx = len(options) // 2
    return [options[i] for i in range(max(0, idx-1), min(len(options), idx+2))]

#Compute metrics
def compute_clinical_metrics(y_true, y_pred):
    cm = confusion_matrix(y_true, y_pred, labels=[0, 1])
    TN, FP, FN, TP = cm.ravel()
    acc = accuracy_score(y_true, y_pred)
    kappa = cohen_kappa_score(y_true, y_pred)
    type1_error = FP / (FP + TN) if (FP + TN) > 0 else 0.0
    power = TP / (TP + FN) if (TP + FN) > 0 else 0.0
    return {
        'accuracy': acc, 'kappa': kappa,
        'type1_error': type1_error, 'power': power,
        'TP': int(TP), 'FP': int(FP), 'TN': int(TN), 'FN': int(FN)
    }

#Load primary data
X_primary, y_primary = load_and_preprocess_data(primary_data_path, feature_cols, remove_nans=True)

#Split 50/25/25
X_temp, X_test, y_temp, y_test = train_test_split(
    X_primary, y_primary, test_size=test_size,
    random_state=random_state, stratify=y_primary
)
X_train, X_val, y_train, y_val = train_test_split(
    X_temp, y_temp, test_size=val_size,
    random_state=random_state, stratify=y_temp
)

print(f"Train: {X_train.shape[0]}, Val: {X_val.shape[0]}, Test: {X_test.shape[0]}")

#Scale
scaler = StandardScaler()
X_train_scaled = scaler.fit_transform(X_train)
X_val_scaled = scaler.transform(X_val)
X_test_scaled = scaler.transform(X_test)

#Load secondary datasets
X_tcns, y_tcns = load_and_preprocess_data(secondary_local_paths[0], feature_cols, remove_nans=False)
X_tcs, y_tcs = load_and_preprocess_data(secondary_local_paths[1], feature_cols, remove_nans=False)
X_tcns_scaled = scaler.transform(X_tcns)
X_tcs_scaled = scaler.transform(X_tcs)

#Hyperparameter search - problem-solved due to not having precedent for parameters
xgb_param_space = {
    'max_depth': [3, 5, 7, 9, 11],
    'learning_rate': [0.01, 0.05, 0.1, 0.2, 0.3],
    'n_estimators': [100, 200, 300, 500],
    'subsample': [0.7, 0.8, 0.9, 1.0],
    'colsample_bytree': [0.7, 0.8, 0.9, 1.0],
    'min_child_weight': [1, 3, 5, 7],
}

#Class weight
n_pos = y_train.sum()
n_neg = len(y_train) - n_pos
scale_pos_weight = n_neg / n_pos if n_pos > 0 else 1

best_kappa = -1
best_params = None

#Phase 1: Random search
print(f"Phase 1: Random Search ({phase1_trials} trials)")
search_start = time.time()

np.random.seed(random_state)
for trial in range(phase1_trials):
    params = {
        'max_depth': int(np.random.choice(xgb_param_space['max_depth'])),
        'learning_rate': float(np.random.choice(xgb_param_space['learning_rate'])),
        'n_estimators': int(np.random.choice(xgb_param_space['n_estimators'])),
        'subsample': float(np.random.choice(xgb_param_space['subsample'])),
        'colsample_bytree': float(np.random.choice(xgb_param_space['colsample_bytree'])),
        'min_child_weight': int(np.random.choice(xgb_param_space['min_child_weight'])),
    }

    try:
        model = xgb.XGBClassifier(
            **params, scale_pos_weight=scale_pos_weight,
            eval_metric='logloss', random_state=random_state,
            n_jobs=-1, use_label_encoder=False
        )
        model.fit(X_train_scaled, y_train,
                  eval_set=[(X_val_scaled, y_val)], verbose=False)
        y_tcns_proba = model.predict_proba(X_tcns_scaled)[:, 1]
        threshold, kappa = optimize_threshold(y_tcns, y_tcns_proba)
        print(f"  Trial {trial+1}: depth={params['max_depth']} lr={params['learning_rate']} "
              f"n_est={params['n_estimators']} sub={params['subsample']} "
              f"col={params['colsample_bytree']} → κ={kappa:.4f}")
        if kappa > best_kappa:
            best_kappa = kappa
            best_params = params.copy()
    except Exception as e:
        print(f"  Trial {trial+1}: FAILED ({e})")

print(f"Best Phase 1: κ={best_kappa:.4f}, Params: {best_params}")

#Phase 2: Grid search around best
print(f"\nPhase 2: Grid Search ({phase2_trials} trials)")

depth_neighbors = get_neighbors(best_params['max_depth'], xgb_param_space['max_depth'])
lr_neighbors = get_neighbors(best_params['learning_rate'], xgb_param_space['learning_rate'])
n_est_neighbors = get_neighbors(best_params['n_estimators'], xgb_param_space['n_estimators'])

combos = list(product(depth_neighbors, lr_neighbors, n_est_neighbors))
np.random.seed(random_state + 100)
if len(combos) > phase2_trials:
    idx = np.random.choice(len(combos), phase2_trials, replace=False)
    combos = [combos[i] for i in idx]

for i, (depth, lr, n_est) in enumerate(combos):
    params = best_params.copy()
    params['max_depth'] = int(depth)
    params['learning_rate'] = float(lr)
    params['n_estimators'] = int(n_est)

    try:
        model = xgb.XGBClassifier(
            **params, scale_pos_weight=scale_pos_weight,
            eval_metric='logloss', random_state=random_state,
            n_jobs=-1, use_label_encoder=False
        )
        model.fit(X_train_scaled, y_train,
                  eval_set=[(X_val_scaled, y_val)], verbose=False)
        y_tcns_proba = model.predict_proba(X_tcns_scaled)[:, 1]
        threshold, kappa = optimize_threshold(y_tcns, y_tcns_proba)
        print(f"  Trial {i+1}: depth={depth} lr={lr} n_est={n_est} → κ={kappa:.4f}")
        if kappa > best_kappa:
            best_kappa = kappa
            best_params = params.copy()
    except Exception as e:
        print(f"  Trial {i+1}: FAILED ({e})")

search_duration = time.time() - search_start
print(f"Best overall: κ={best_kappa:.4f}, Params: {best_params}")
print(f"Search duration: {search_duration:.1f}s")

#Final training
train_start = time.time()

final_model = xgb.XGBClassifier(
    **best_params, scale_pos_weight=scale_pos_weight,
    eval_metric='logloss', random_state=random_state,
    n_jobs=-1, use_label_encoder=False
)
final_model.fit(X_train_scaled, y_train,
                eval_set=[(X_val_scaled, y_val)], verbose=False)

train_duration = time.time() - train_start
print(f"\nFinal model trained in {train_duration:.1f}s")
print(f"Params: {best_params}")

#Feature importance
importances = final_model.feature_importances_
feat_imp = sorted(zip(feature_cols, importances), key=lambda x: x[1], reverse=True)
print("\nFeature Importance (top 10):")
for feat, imp in feat_imp[:10]:
    print(f"  {feat}: {imp:.4f}")

#Threshold optimization on TCNS
val_start = time.time()

y_tcns_proba = final_model.predict_proba(X_tcns_scaled)[:, 1]
best_threshold, best_threshold_kappa = optimize_threshold(y_tcns, y_tcns_proba)

y_val_proba = final_model.predict_proba(X_val_scaled)[:, 1]
y_val_pred = (y_val_proba >= best_threshold).astype(int)
val_metrics = compute_clinical_metrics(y_val, y_val_pred)

val_duration = time.time() - val_start

print(f"\nOptimal threshold: {best_threshold:.3f}")
print(f"Validation - Acc: {val_metrics['accuracy']:.4f}, κ: {val_metrics['kappa']:.4f}, "
      f"Type1: {val_metrics['type1_error']:.4f}, Power: {val_metrics['power']:.4f}")

#Test evaluation
all_results = {}

#Primary test
test_start = time.time()
