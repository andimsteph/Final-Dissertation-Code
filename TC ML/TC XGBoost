test_duration = time.time() - test_start
all_results['Primary Test'] = {**test_metrics, 'threshold': best_threshold,
                                'duration_s': test_duration, 'n': len(y_test)}

#TCNS
tcns_start = time.time()
y_tcns_pred = (y_tcns_proba >= best_threshold).astype(int)
