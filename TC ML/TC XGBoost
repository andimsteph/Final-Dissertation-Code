primary_drive_path = '/content/drive/My Drive/FinalTCRuns/combined_simulations_features_normalized.csv'
primary_local_path = '/content/data/combined_simulations_features_normalized.csv'
!cp "{primary_drive_path}" "{primary_local_path}"

secondary_drive_paths = [
    '/content/drive/My Drive/FinalTCRuns/TCNS_v6_raw_features_normalized_GROUPED.csv',
    '/content/drive/My Drive/FinalTCRuns/TCS_v2_raw_features_normalized.csv'
