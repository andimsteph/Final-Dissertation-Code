#Import packages
import os
import pickle
import numpy as np
import pandas as pd
from sklearn.cluster import KMeans
from sklearn.linear_model import LinearRegression

#Paths and load data
base_dir = '/content/drive/MyDrive/NewTCpickles'
pkl_file = os.path.join(base_dir, 'alltc_swapped.pkl')

with open(pkl_file, 'rb') as f:
    data_list = pickle.load(f)

#Standardize data and feature extraction
def standardize_data(x):
    indexControl = np.where(x[0] == 'Control')
    indexTest = np.where(x[0] == 'Test')

    Control = x[1][indexControl].astype(float).flatten()
    Test = x[1][indexTest].astype(float).flatten()

    overallMean = np.mean(np.hstack((Control, Test)))
    overallSd = np.std(np.hstack((Control, Test)))

    Control_norm = (Control - overallMean) / overallSd
    Control_norm[np.isnan(Control_norm)] = 0
    Test_norm = (Test - overallMean) / overallSd
    Test_norm[np.isnan(Test_norm)] = 0

    pointsControl = len(Control_norm)
    pointsTotal = pointsControl + len(Test_norm)

    features = []
    
    #Mean and standard deviation
    features.append([np.mean(Control_norm), np.mean(Test_norm)])
    features.append([np.std(Control_norm), np.std(Test_norm)])

    #LR for control
    if pointsControl > 1:
        lm1 = LinearRegression().fit(np.arange(pointsControl).reshape(-1, 1),
                                     Control_norm.reshape(-1, 1))
        #Intercept and coefficient values
        intercept_c = lm1.intercept_[0] if np.ndim(lm1.intercept_) > 0 else lm1.intercept_
        coef_c = lm1.coef_[0][0] if np.ndim(lm1.coef_) > 0 else lm1.coef_
        features.append([float(intercept_c), float(coef_c)])
    else:
        features.append([0, 0])

    #LR for test
    if len(Test_norm) > 1:
        lm2 = LinearRegression().fit(np.arange(pointsControl, pointsTotal).reshape(-1, 1),
                                     Test_norm.reshape(-1, 1))
        intercept_t = lm2.intercept_[0] if np.ndim(lm2.intercept_) > 0 else lm2.intercept_
        coef_t = lm2.coef_[0][0] if np.ndim(lm2.coef_) > 0 else lm2.coef_
        features.append([float(intercept_t), float(coef_t)])
    else:
        features.append([0, 0])

    return np.array(features).flatten(), Control_norm, Test_norm

#CSV columns
columns = [
    'Mean Control', 'Mean Test',
    'Std Control', 'Std Test',
    'Intercept Control', 'Slope Control',
    'Intercept Test', 'Slope Test',
    'IQR Control', 'IQR Test',
    'Stability Control', 'Stability Test',
    'PND Control-Test',
    'Highest Response Condition',
    'Cluster Similarity Test',
    'Differentiation Type'
]
num_cols = len(columns)

all_features = []

#Run all simulations from the .pkl
for idx, item in enumerate(data_list):
    labels = item['labels']
    values = item['values']
    smd    = item['SMD'] #groud truth

    try:
        #Call standardized data
        norm_features, Control_norm, Test_norm = standardize_data((labels, values))

        #IQR
        if len(Control_norm) > 0:
            q75c, q25c = np.percentile(Control_norm, [75, 25])
            iqr_control = q75c - q25c
        else:
            iqr_control = 0
        if len(Test_norm) > 0:
            q75t, q25t = np.percentile(Test_norm, [75, 25])
            iqr_test = q75t - q25t
        else:
            iqr_test = 0

        #Stability
        mean_control = norm_features[0]
        mean_test = norm_features[1]
        std_control = norm_features[2]
        std_test = norm_features[3]
        stability_control = std_control / mean_control if mean_control != 0 else 0
        stability_test = std_test / mean_test if mean_test != 0 else 0

        #PND
        threshold = np.max(Control_norm) if len(Control_norm) > 0 else 0
        above_threshold = [v for v in Test_norm if v > threshold]
        pnd_control_test = len(above_threshold) / len(Test_norm) if len(Test_norm) > 0 else 0

        #Highest response condition
        highest_response = 0 if mean_control > mean_test else 1

        #Cluster simularity
        kmeans_data = np.array([mean_control, mean_test]).reshape(-1, 1)
        if len(np.unique(kmeans_data)) == 1:
            cluster_similarity_test = 1
        else:
            kmeans = KMeans(n_clusters=2, random_state=0).fit(kmeans_data)
            labels_k = kmeans.labels_
            cluster_similarity_test = int(labels_k[0] == labels_k[1])

        #Ground truth
        diff_type = 'differentiated' if smd >= 1.44 else 'undifferentiated'

        #Combine
        features = list(norm_features) + [iqr_control, iqr_test, stability_control, stability_test,
                                          pnd_control_test, highest_response, cluster_similarity_test, diff_type]
    except Exception as e:
        print(f"Error at index {idx}: {e}")
        features = [0] * num_cols

    #Ensure vector is the correct length
    if len(features) < num_cols:
        features += [0] * (num_cols - len(features))
    elif len(features) > num_cols:
        features = features[:num_cols]

    all_features.append(features)

#Build data and save
df = pd.DataFrame(all_features, columns=columns)
output_csv = os.path.join(base_dir, 'FIXED_combined_simulations_features_normalized.csv')
df.to_csv(output_csv, index=False)
print("Saved:", output_csv)
